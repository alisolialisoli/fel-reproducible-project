# --------------------------------------------------
# MATLAB temporary/editor files
# --------------------------------------------------
*.asv
*.m~
*.mlx.autosave

# --------------------------------------------------
# Operating system files
# --------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --------------------------------------------------
# Logs
# --------------------------------------------------
*.log
slurm-*.out
slurm-*.err

# --------------------------------------------------
# Raw simulation data (too large for git)
# --------------------------------------------------
data/raw/*.h5

# --------------------------------------------------
# Processed/intermediate data
# --------------------------------------------------
data/processed/*
!data/processed/.gitkeep

# --------------------------------------------------
# Generated figures
# --------------------------------------------------
results/figures/*.png
results/figures/*.jpg
results/figures/*.jpeg
results/figures/*.pdf
results/figures/*.svg

# --------------------------------------------------
# Generated tables
# --------------------------------------------------
results/tables/*.csv
results/tables/*.txt
results/tables/*.dat

# --------------------------------------------------
# Optional MATLAB binary data
# --------------------------------------------------
*.mat

# --------------------------------------------------
# Backup files
# --------------------------------------------------
*~